           (urhc (vec-add mid-left (vec-mul dy-vec (- dy))))
           (lrhc (vec-add mid-left (vec-mul dy-vec dy)))
           (ulhc (vec-add urhc (vec-mul dx-vec ?x)))
           (llhc (vec-add lrhc (vec-mul dx-vec ?x)))
           (region (map vec->ints (list ulhc urhc llhc lrhc))))
