; claim a relative region based on detected tag dimensions
; x and y are scaling factors with base equal to tags inner box vectors
; dist scales with same vector, but is distance from the tag center
(When ((?someone wishes (?p has-region-right (?region ?x ?y ?dist)))
       (?p (page points) (?ulhc ?urhc ?llhc ?lrhc)))
 do (let* ((dx-vec (vec-from-to ?ulhc ?urhc))
           (dy-vec (vec-from-to ?ulhc ?llhc))
           (dx (/ ?x 2.0)) (dy (/ ?y 2.0))
           (diagonal (vec-from-to ?ulhc ?lrhc))
           (mid (vec-add ?ulhc (vec-mul diagonal 0.5)))
           (mid-right (vec-add mid (vec-mul dx-vec (+ 1 ?dist))))
           (ulhc (vec-add mid-right (vec-mul dy-vec (- dy))))
           (llhc (vec-add mid-right (vec-mul dy-vec dy)))
           (urhc (vec-add ulhc (vec-mul dx-vec ?x)))
           (lrhc (vec-add llhc (vec-mul dx-vec ?x)))
           (region (map vec->ints (list ulhc urhc llhc lrhc))))
       (Claim ?p 'has-region (cons ?region region))))

